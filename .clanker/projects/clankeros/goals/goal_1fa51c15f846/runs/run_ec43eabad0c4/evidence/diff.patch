+def _handoff_file_list(structured_output: dict[str, Any], key: str) -> list[str]:
+    value = structured_output.get(key, [])
+    if isinstance(value, str):
+        return [value]
+    if not isinstance(value, list):
+        return []
+    return [str(item) for item in value if str(item)]
